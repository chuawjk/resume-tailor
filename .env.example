# OpenAI API key — required for all LLM agents
export OPENAI_API_KEY="sk-..."

# Models (defaults shown)
# Extraction, gap analysis, and tailoring agents
export RESUME_TAILOR_MODEL="gpt-5.4-mini"
# Fabrication judge uses a stronger model
export RESUME_TAILOR_JUDGE_MODEL="gpt-5.4"

# Editor opened at each human-in-the-loop checkpoint
# Falls back to "vi" if unset
export EDITOR="code --wait"
